{
  "name": "@helios-cloud/cli",
  "version": "0.1.0",
  "description": "HELIOS command-line interface",
  "bin": {
    "helios": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx src/bin.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@helios-cloud/core": "workspace:*",
    "@helios-cloud/optimizer": "workspace:*",
    "@helios-cloud/drift": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "cli-table3": "^0.6.4",
    "yaml": "^2.4.2",
    "enquirer": "^2.4.1",
    "boxen": "^7.1.1",
    "figures": "^6.1.0",
    "gradient-string": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/cli-table3": "^0.6.4",
    "@types/gradient-string": "^1.1.6",
    "tsx": "^4.11.0",
    "vitest": "^1.6.0",
    "typescript": "^5.4.5"
  }
}
