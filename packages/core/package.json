{
  "name": "@helios-cloud/core",
  "version": "0.1.0",
  "description": "HELIOS core orchestration engine",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "zod": "^3.23.8",
    "pino": "^9.1.0",
    "uuid": "^9.0.1",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/uuid": "^9.0.8",
    "vitest": "^1.6.0",
    "typescript": "^5.4.5"
  }
}
