{
  "name": "@helios-cloud/api",
  "version": "0.1.0",
  "description": "HELIOS REST API and WebSocket server",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@helios-cloud/core": "workspace:*",
    "@helios-cloud/optimizer": "workspace:*",
    "@helios-cloud/drift": "workspace:*",
    "fastify": "^4.26.2",
    "fastify-plugin": "^4.5.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@fastify/websocket": "^8.3.1",
    "@fastify/jwt": "^8.0.1",
    "pino": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.11.0",
    "vitest": "^1.6.0",
    "typescript": "^5.4.5"
  }
}
